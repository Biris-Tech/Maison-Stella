generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Room {
  id          String  @id
  name        String
  price       Int
  capacity    Int
  bedType     String
  desc        String  @db.Text
  badge       String  @default("")
  composition Json
  amenities   Json
  images      Json
  featured    Boolean @default(false)
  active      Boolean @default(true)
}

model Booking {
  id            String   @id
  room          String
  roomId        String?
  checkin       String
  checkout      String
  fullname      String?
  phone         String?
  email         String?
  guests        Int?
  nights        Int?
  totalAmount   Int?
  status        String   @default("pending")
  paymentMethod String?
  paymentStatus String   @default("unpaid")
  paymentId     String?
  createdAt     DateTime @default(now())
}

model ContactMessage {
  id        String   @id
  firstname String
  lastname  String
  phone     String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AdminUser {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         String        @default("writer")
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  logs         ActivityLog[]
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String    @db.Text
  content     String    @db.LongText
  coverImage  String    @default("")
  authorId    String
  authorName  String
  status      String    @default("draft")
  tags        Json      @default("[]")
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ActivityLog {
  id        String    @id @default(cuid())
  userId    String
  userName  String
  action    String
  details   Json?
  ip        String    @default("")
  createdAt DateTime  @default(now())
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Setting {
  id          String @id
  siteName    String
  tagline     String
  description String @db.Text
  address     String
  phone       String
  email       String
  heroImage   String
  aboutText   String @db.Text
  aboutText2  String @db.Text
  adminPlain  String @default("stella2026")
  services    Json
}
