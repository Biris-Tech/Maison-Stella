<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog – <%= settings.siteName %></title>
  <meta name="description" content="Actualités, conseils et inspirations de <%= settings.siteName %> à Avepozo, Lomé.">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= canonical %>">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Blog – <%= settings.siteName %>">
  <meta property="og:description" content="Actualités, conseils et inspirations de <%= settings.siteName %>.">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:image" content="<%= baseUrl %>/image/<%= encodeURIComponent(settings.heroImage) %>">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="icon" href="/image/logo.png" type="image/png">
  <style>
    .blog-hero { background: var(--dark); padding: 5rem 0 3rem; text-align: center; }
    .blog-hero h1 { color: #fff; font-size: clamp(1.8rem,4vw,3rem); margin-bottom: 0.5rem; }
    .blog-hero p { color: rgba(255,255,255,0.6); font-size: 1rem; }
    .blog-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 2rem; }
    @media (max-width:1100px) { .blog-grid { grid-template-columns: repeat(2,1fr); } }
    @media (max-width:640px) { .blog-grid { grid-template-columns: 1fr; } }
    .blog-card { background: #fff; border-radius: 16px; overflow: hidden; box-shadow: var(--shadow); transition: transform 0.2s, box-shadow 0.2s; }
    .blog-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-hover); }
    .blog-card-img { aspect-ratio: 16/9; overflow: hidden; background: var(--bg-gray); }
    .blog-card-img img { width: 100%; height: 100%; object-fit: cover; }
    .blog-card-body { padding: 1.25rem; }
    .blog-card-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.6rem; }
    .blog-card-title { font-size: 1.05rem; font-weight: 700; color: var(--dark); margin-bottom: 0.4rem; line-height: 1.4; }
    .blog-card-excerpt { font-size: 0.88rem; color: var(--muted); line-height: 1.6; margin-bottom: 1rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .blog-card-footer { display: flex; align-items: center; justify-content: space-between; font-size: 0.8rem; color: var(--muted); }
    .blog-pagination { display: flex; gap: 0.5rem; justify-content: center; margin-top: 3rem; }
    .blog-pagination a, .blog-pagination span { padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid var(--border); font-size: 0.88rem; text-decoration: none; color: var(--text); }
    .blog-pagination a:hover { background: var(--bg-gray); }
    .blog-pagination .current { background: var(--primary); color: #fff; border-color: var(--primary); }
  </style>
</head>
<body>

<%- include('../partials/nav', { page: 'blog', settings }) %>

<div class="blog-hero">
  <div class="container">
    <p class="eyebrow">Actualités & Inspirations</p>
    <h1>Notre Blog</h1>
    <p>Conseils, découvertes et histoires autour de <%= settings.siteName %></p>
  </div>
</div>

<section class="section">
  <div class="container">
    <% if (posts.length === 0) { %>
    <div style="text-align:center;padding:4rem 0;color:var(--muted);">
      <p style="font-size:1.1rem;">Aucun article publié pour l'instant.</p>
      <a href="/" class="btn-primary" style="margin-top:1.5rem;display:inline-block;">Retour à l'accueil</a>
    </div>
    <% } else { %>
    <div class="blog-grid">
      <% posts.forEach(post => { %>
      <a href="/blog/<%= post.slug %>" class="blog-card" style="text-decoration:none;">
        <div class="blog-card-img">
          <% if (post.coverImage) { %>
          <img src="/image/<%= encodeURIComponent(post.coverImage) %>" alt="<%= post.title %>" loading="lazy">
          <% } else { %>
          <div style="width:100%;height:100%;background:linear-gradient(135deg,var(--primary),#e07050);display:flex;align-items:center;justify-content:center;">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <% } %>
        </div>
        <div class="blog-card-body">
          <% if (post.tags && post.tags.length) { %>
          <div class="blog-card-tags">
            <% post.tags.slice(0,3).forEach(t => { %><span class="amenity-tag"><%= t %></span><% }) %>
          </div>
          <% } %>
          <h2 class="blog-card-title"><%= post.title %></h2>
          <% if (post.excerpt) { %><p class="blog-card-excerpt"><%= post.excerpt %></p><% } %>
          <div class="blog-card-footer">
            <span><%= post.authorName %></span>
            <span><%= new Date(post.publishedAt).toLocaleDateString('fr-FR', { day:'2-digit', month:'short', year:'numeric' }) %></span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>

    <% if (totalPages > 1) { %>
    <div class="blog-pagination">
      <% if (page > 1) { %><a href="/blog?page=<%= page - 1 %>">← Précédent</a><% } %>
      <% for (let i = 1; i <= totalPages; i++) { %>
        <% if (i === page) { %><span class="current"><%= i %></span>
        <% } else { %><a href="/blog?page=<%= i %>"><%= i %></a><% } %>
      <% } %>
      <% if (page < totalPages) { %><a href="/blog?page=<%= page + 1 %>">Suivant →</a><% } %>
    </div>
    <% } %>
    <% } %>
  </div>
</section>

<%- include('../partials/footer', { settings }) %>
<script src="/js/main.js"></script>
<script>
  window.addEventListener('load', () => { const p = document.getElementById('preloader'); if (p) p.classList.add('fade-out'); });
</script>
</body>
</html>
