<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Journal – <%= settings.siteName %></title>
  <meta name="description" content="Actualités, conseils et inspirations de <%= settings.siteName %> à Avepozo, Lomé.">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= canonical %>">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Journal – <%= settings.siteName %>">
  <meta property="og:description" content="Actualités, conseils et inspirations de <%= settings.siteName %>.">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:image" content="<%= baseUrl %>/image/<%= encodeURIComponent(settings.heroImage) %>">
  <meta name="twitter:card" content="summary_large_image">
  <script>document.documentElement.classList.add('js');</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/home.css?v=3">
  <link rel="icon" href="/image/logo.png" type="image/png">
</head>
<body>

<%- include('../partials/site-nav', { settings }) %>

<header class="page-head">
  <div class="wrap">
    <p class="breadcrumb reveal"><a href="/">Accueil</a> · Journal</p>
    <h1 class="reveal">Le <em>journal</em></h1>
    <p class="sub reveal">Conseils, découvertes et histoires autour de <%= settings.siteName %>.</p>
  </div>
</header>

<section style="padding-bottom: clamp(4rem, 9vw, 8rem)">
  <div class="wrap">
    <% if (posts.length === 0) { %>
    <div class="ch-empty reveal">
      <h3>Le journal arrive bientôt</h3>
      <p>Nos premières histoires et inspirations seront publiées ici très prochainement.</p>
      <a href="/chambres" class="btn btn-p">Voir nos chambres</a>
    </div>
    <% } else { %>
    <div class="blog-grid">
      <% posts.forEach(post => { %>
      <a href="/blog/<%= post.slug %>" class="blog-card reveal">
        <div class="blog-card-img">
          <% if (post.coverImage) { %>
          <img src="/image/<%= encodeURIComponent(post.coverImage) %>" alt="<%= post.title %>" loading="lazy">
          <% } %>
        </div>
        <div class="blog-card-body">
          <% if (post.tags && post.tags.length) { %>
          <div class="blog-tags"><% post.tags.slice(0,3).forEach(t => { %><span class="blog-tag"><%= t %></span><% }) %></div>
          <% } %>
          <h2 class="blog-card-title"><%= post.title %></h2>
          <% if (post.excerpt) { %><p class="blog-card-excerpt"><%= post.excerpt %></p><% } %>
          <div class="blog-card-foot">
            <span><%= post.authorName %></span>
            <span><%= new Date(post.publishedAt).toLocaleDateString('fr-FR', { day:'2-digit', month:'short', year:'numeric' }) %></span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>

    <% if (totalPages > 1) { %>
    <div class="blog-pagination">
      <% if (page > 1) { %><a href="/blog?page=<%= page - 1 %>">← Précédent</a><% } %>
      <% for (let i = 1; i <= totalPages; i++) { %>
        <% if (i === page) { %><span class="current"><%= i %></span><% } else { %><a href="/blog?page=<%= i %>"><%= i %></a><% } %>
      <% } %>
      <% if (page < totalPages) { %><a href="/blog?page=<%= page + 1 %>">Suivant →</a><% } %>
    </div>
    <% } %>
    <% } %>
  </div>
</section>

<%- include('../partials/site-footer', { settings }) %>
<script src="/js/site.js"></script>
</body>
</html>
