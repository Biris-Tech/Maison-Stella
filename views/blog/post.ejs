<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= post.title %> – <%= settings.siteName %></title>
  <meta name="description" content="<%= post.excerpt ? post.excerpt.substring(0,160) : post.title %>">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= canonical %>">
  <meta property="og:type" content="article">
  <meta property="og:locale" content="fr_FR">
  <meta property="og:site_name" content="<%= settings.siteName %>">
  <meta property="og:title" content="<%= post.title %>">
  <meta property="og:description" content="<%= post.excerpt ? post.excerpt.substring(0,200) : post.title %>">
  <meta property="og:url" content="<%= canonical %>">
  <% if (post.coverImage) { %>
  <meta property="og:image" content="<%= baseUrl %>/image/<%= encodeURIComponent(post.coverImage) %>">
  <% } %>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= post.title %>">
  <meta name="twitter:description" content="<%= post.excerpt ? post.excerpt.substring(0,200) : post.title %>">
  <% if (post.coverImage) { %>
  <meta name="twitter:image" content="<%= baseUrl %>/image/<%= encodeURIComponent(post.coverImage) %>">
  <% } %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "<%= post.title.replace(/"/g,'&quot;') %>",
    "description": "<%= (post.excerpt || '').replace(/"/g,'&quot;') %>",
    "url": "<%= canonical %>",
    "datePublished": "<%= post.publishedAt %>",
    "author": { "@type": "Person", "name": "<%= post.authorName %>" },
    "publisher": { "@type": "Organization", "name": "<%= settings.siteName %>" }
  }
  </script>
  <script>document.documentElement.classList.add('js');</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/home.css?v=3">
  <link rel="icon" href="/image/logo.png" type="image/png">
</head>
<body>

<%- include('../partials/site-nav', { settings }) %>

<article>
  <div class="article article-head">
    <p class="breadcrumb"><a href="/">Accueil</a> · <a href="/blog">Journal</a></p>
    <% if (post.tags && post.tags.length) { %>
    <div class="blog-tags"><% post.tags.slice(0,3).forEach(t => { %><span class="blog-tag"><%= t %></span><% }) %></div>
    <% } %>
    <h1 class="article-title"><%= post.title %></h1>
    <div class="article-meta">
      <span>Par <%= post.authorName %></span>
      <span>·</span>
      <span><%= new Date(post.publishedAt).toLocaleDateString('fr-FR', { day:'2-digit', month:'long', year:'numeric' }) %></span>
    </div>
  </div>

  <% if (post.coverImage) { %>
  <div class="article"><img src="/image/<%= encodeURIComponent(post.coverImage) %>" alt="<%= post.title %>" class="article-cover"></div>
  <% } %>

  <div class="article">
    <div class="article-body"><%- post.content %></div>
  </div>

  <div class="article-foot">
    <a href="/blog" class="btn btn-o">← Retour au journal</a>
    <div class="share-row">
      <a href="https://wa.me/?text=<%= encodeURIComponent(post.title + ' — ' + canonical) %>" target="_blank" rel="noopener">WhatsApp</a>
      <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(canonical) %>" target="_blank" rel="noopener">Facebook</a>
      <button onclick="navigator.clipboard.writeText('<%= canonical %>').then(()=>{ this.textContent='Lien copié !'; })">Copier le lien</button>
    </div>
  </div>
</article>

<%- include('../partials/site-footer', { settings }) %>
<script src="/js/site.js"></script>
</body>
</html>
