<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= room.name %> – <%= settings.siteName %></title>
  <meta name="description" content="<%= room.desc.substring(0,160) %> | <%= room.capacity %> personnes · <%= room.bedType %> · <%= room.price.toLocaleString('fr-FR') %> FCFA/nuit.">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= canonical %>">

  <meta property="og:type" content="product">
  <meta property="og:locale" content="fr_FR">
  <meta property="og:site_name" content="<%= settings.siteName %>">
  <meta property="og:title" content="<%= room.name %> – <%= settings.siteName %>">
  <meta property="og:description" content="<%= room.desc.substring(0,200) %>">
  <meta property="og:url" content="<%= canonical %>">
  <% if (room.images.length > 0) { %>
  <meta property="og:image" content="<%= baseUrl %>/image/<%= encodeURIComponent(room.images[0]) %>">
  <% } %>

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= room.name %> – <%= settings.siteName %>">
  <meta name="twitter:description" content="<%= room.desc.substring(0,200) %>">
  <% if (room.images.length > 0) { %>
  <meta name="twitter:image" content="<%= baseUrl %>/image/<%= encodeURIComponent(room.images[0]) %>">
  <% } %>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "HotelRoom",
    "name": "<%= room.name %>",
    "description": "<%= room.desc.replace(/"/g,'&quot;').replace(/\n/g,' ') %>",
    "url": "<%= canonical %>",
    "occupancy": { "@type": "QuantitativeValue", "maxValue": <%= room.capacity %> },
    "bed": [{ "@type": "BedDetails", "typeOfBed": "<%= room.bedType %>" }],
    <% if (room.images.length > 0) { %>"image": "<%= baseUrl %>/image/<%= encodeURIComponent(room.images[0]) %>",<% } %>
    "offers": { "@type": "Offer", "price": "<%= room.price %>", "priceCurrency": "XOF", "availability": "https://schema.org/InStock" },
    "containedInPlace": { "@type": "LodgingBusiness", "name": "<%= settings.siteName %>", "address": "<%= settings.address.replace(/"/g,'&quot;') %>" }
  }
  </script>

  <script>document.documentElement.classList.add('js');</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <% if (room.images.length > 0) { %>
  <link rel="preload" as="image" href="/image/<%= encodeURIComponent(room.images[0]) %>">
  <% } %>
  <link rel="stylesheet" href="/css/home.css">
  <link rel="icon" href="/image/logo.png" type="image/png">
  <% if (paypalClientId) { %>
  <script src="https://www.paypal.com/sdk/js?client-id=<%= paypalClientId %>&currency=EUR" defer></script>
  <% } %>
</head>
<body>

<%- include('partials/site-nav', { settings }) %>

<div class="detail-wrap">
  <div class="wrap">
    <div class="detail-top">
      <div>
        <p class="breadcrumb"><a href="/">Accueil</a> · <a href="/chambres">Chambres</a> · <%= room.name %></p>
        <h1><%= room.name %></h1>
        <div class="detail-meta">
          <span class="star">★ 4,9 · 12 avis</span>
          <span>·</span>
          <span><%= settings.address %></span>
          <% if (room.badge) { %><span class="badge"><%= room.badge %></span><% } %>
        </div>
      </div>
      <button class="share" onclick="copyLink()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        Partager
      </button>
    </div>

    <!-- GALLERY -->
    <div class="gallery">
      <div class="gallery-main-slot" id="galleryMain" role="button" tabindex="0" aria-label="Ouvrir la galerie" onclick="openLightbox(0)" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();openLightbox(0)}">
        <img id="mainImg" src="/image/<%= encodeURIComponent(room.images[0]) %>" alt="<%= room.name %>">
        <button class="gallery-all-btn" onclick="event.stopPropagation(); openLightbox(0)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          Voir tout
        </button>
      </div>
      <div class="gallery-side">
        <% room.images.slice(1, 3).forEach((img, i) => { %>
        <div class="gallery-thumb" role="button" tabindex="0" aria-label="Photo <%= i+2 %>" onclick="setMainImg(<%= i+1 %>)" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();setMainImg(<%= i+1 %>)}">
          <img src="/image/<%= encodeURIComponent(img) %>" alt="<%= room.name %> — photo <%= i+2 %>" loading="lazy">
        </div>
        <% }) %>
      </div>
    </div>

    <div class="detail-layout">
      <!-- CONTENU -->
      <div class="detail-content">
        <h2>Chambre chez <%= settings.siteName %></h2>
        <p class="detail-specs"><%= room.capacity %> voyageur<%= room.capacity > 1 ? 's' : '' %> · <%= room.bedType %></p>

        <div class="detail-block">
          <p class="detail-desc"><%= room.desc %></p>
        </div>

        <div class="detail-block">
          <h3>Ce que propose ce logement</h3>
          <div class="feature-grid">
            <% room.composition.forEach(item => { %>
            <div class="feature-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg><%= item %></div>
            <% }) %>
            <% room.amenities.forEach(item => { %>
            <div class="feature-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg><%= item %></div>
            <% }) %>
          </div>
        </div>

        <div class="detail-block">
          <h3>★ 4,9 · <span style="font-weight:400;color:var(--ink-soft);font-family:var(--sans);font-size:1rem">12 avis</span></h3>
          <div class="reviews">
            <div class="review">
              <div class="review-head"><div class="review-av">K</div><div><strong>Kossi A.</strong><br><small>Mars 2026</small></div></div>
              <p>« Séjour excellent, chambre impeccable et personnel aux petits soins. Je recommande vivement Maison Stella ! »</p>
            </div>
            <div class="review">
              <div class="review-head"><div class="review-av">A</div><div><strong>Ama S.</strong><br><small>Février 2026</small></div></div>
              <p>« Cadre magnifique, piscine superbe. La chambre était exactement comme sur les photos. Parfait ! »</p>
            </div>
          </div>
        </div>
      </div>

      <!-- RÉSERVATION -->
      <div class="booking-side">
        <div class="book-card" id="bookingCard">
          <div class="book-price"><strong><%= room.price.toLocaleString('fr-FR') %></strong><span>FCFA / nuit</span></div>
          <div class="book-rating">★ 4,9 · 12 avis</div>

          <!-- ÉTAPE 1 -->
          <div id="stepForm">
            <div class="book-dates">
              <div class="bf"><label for="checkin">Arrivée</label><input type="date" id="checkin" required></div>
              <div class="bf"><label for="checkout">Départ</label><input type="date" id="checkout" required></div>
            </div>
            <div class="book-field"><label for="guests">Voyageurs</label>
              <select id="guests">
                <% for(let i=1; i<=room.capacity; i++) { %><option value="<%= i %>"><%= i %> voyageur<%= i > 1 ? 's' : '' %></option><% } %>
              </select>
            </div>
            <div class="book-field"><label for="fullname">Nom complet</label><input type="text" id="fullname" placeholder="Votre nom complet" required></div>
            <div class="book-field"><label for="phone">Téléphone</label><input type="tel" id="phone" placeholder="+228 XX XX XX XX"></div>
            <div class="book-field"><label for="email">E-mail</label><input type="email" id="email" placeholder="email@exemple.com"></div>

            <div class="price-breakdown" id="priceBreakdown" style="display:none;">
              <div class="price-line"><span><%= room.price.toLocaleString('fr-FR') %> FCFA × <span id="nightsCount">0</span> nuit(s)</span><span id="priceLineTotal">–</span></div>
              <div class="price-line" style="font-size:.82rem;"><span>Équivalent PayPal</span><span id="priceEur">–</span></div>
              <div class="price-line total"><strong>Total XOF</strong><strong id="totalPriceDisplay">–</strong></div>
            </div>

            <div id="formError" class="form-error" style="display:none;"></div>
            <button class="btn btn-p btn-full" style="margin-top:1rem;" onclick="proceedToPayment()">Procéder au paiement →</button>
          </div>

          <!-- ÉTAPE 2 -->
          <div id="stepPayment" style="display:none;">
            <div class="pay-recap">
              <div class="pay-recap-row"><span id="recapRoom"><%= room.name %></span><strong id="recapTotal">–</strong></div>
              <div class="pay-recap-dates" id="recapDates">–</div>
            </div>
            <p class="pay-label">Choisissez votre mode de paiement</p>

            <div class="pay-card">
              <div class="pay-card-head">
                <div class="pay-card-info">
                  <div><strong>Mobile Money · Carte</strong><small>Flooz · T-Money · Visa · Mastercard</small></div>
                </div>
                <span class="pay-badge local">Local</span>
              </div>
              <form id="fedapayForm" method="POST" action="/payment/fedapay/init">
                <input type="hidden" name="room" value="<%= room.name %>">
                <input type="hidden" name="roomId" value="<%= room.id %>">
                <input type="hidden" id="fp_checkin" name="checkin">
                <input type="hidden" id="fp_checkout" name="checkout">
                <input type="hidden" id="fp_fullname" name="fullname">
                <input type="hidden" id="fp_phone" name="phone">
                <input type="hidden" id="fp_email" name="email">
                <input type="hidden" id="fp_guests" name="guests">
                <input type="hidden" id="fp_nights" name="nights">
                <input type="hidden" id="fp_totalAmount" name="totalAmount">
                <button type="submit" class="btn-feda" onclick="return fillFedapay()">Payer avec FedaPay</button>
              </form>
            </div>

            <% if (paypalClientId) { %>
            <div class="pay-card">
              <div class="pay-card-head">
                <div class="pay-card-info"><div><strong>PayPal</strong><small>Paiement international en EUR</small></div></div>
                <span class="pay-badge intl">Intl.</span>
              </div>
              <div id="paypal-button-container"></div>
            </div>
            <% } %>

            <button class="book-back" onclick="backToForm()">← Modifier mes infos</button>
          </div>

          <p class="book-note">Paiement sécurisé · Confirmation immédiate</p>
        </div>

        <div class="call-card">
          <p>Préférez appeler ?</p>
          <a href="tel:<%= settings.phone.replace(/\s/g,'') %>" class="btn btn-o btn-full"><%= settings.phone %></a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox" onclick="closeLightboxBg(event)">
  <button class="lb-close" onclick="closeLightbox()" aria-label="Fermer">✕</button>
  <button class="lb-nav lb-prev" onclick="lbNav(-1)" aria-label="Précédent">‹</button>
  <img id="lbImg" src="" alt="">
  <button class="lb-nav lb-next" onclick="lbNav(1)" aria-label="Suivant">›</button>
  <div class="lb-counter" id="lbCounter"></div>
</div>

<%- include('partials/site-footer', { settings }) %>

<script src="/js/site.js"></script>
<script>
  const images       = <%- JSON.stringify(room.images) %>;
  const pricePerNight = <%= room.price %>;
  const XOF_TO_EUR    = 655.957;
  let currentLbIdx = 0;
  let totalAmount  = 0;
  let nights       = 0;

  function setMainImg(idx) {
    currentLbIdx = idx;
    document.getElementById('mainImg').src = '/image/' + encodeURIComponent(images[idx]);
    document.querySelectorAll('.gallery-thumb').forEach((t, i) => t.classList.toggle('active', i === idx - 1));
  }
  function openLightbox(idx) {
    currentLbIdx = idx;
    document.getElementById('lbImg').src = '/image/' + encodeURIComponent(images[idx]);
    document.getElementById('lbCounter').textContent = (idx + 1) + ' / ' + images.length;
    document.getElementById('lightbox').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() { document.getElementById('lightbox').classList.remove('open'); document.body.style.overflow = ''; }
  function closeLightboxBg(e) { if (e.target === document.getElementById('lightbox')) closeLightbox(); }
  function lbNav(dir) {
    currentLbIdx = (currentLbIdx + dir + images.length) % images.length;
    document.getElementById('lbImg').src = '/image/' + encodeURIComponent(images[currentLbIdx]);
    document.getElementById('lbCounter').textContent = (currentLbIdx + 1) + ' / ' + images.length;
  }
  document.addEventListener('keydown', e => {
    if (!document.getElementById('lightbox').classList.contains('open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') lbNav(1);
    if (e.key === 'ArrowLeft') lbNav(-1);
  });

  const today = new Date().toISOString().split('T')[0];
  const checkinEl  = document.getElementById('checkin');
  const checkoutEl = document.getElementById('checkout');
  checkinEl.min = today;

  function updatePrice() {
    const i = checkinEl.value, o = checkoutEl.value;
    if (!i || !o || o <= i) { document.getElementById('priceBreakdown').style.display = 'none'; nights = 0; return; }
    nights      = Math.round((new Date(o) - new Date(i)) / 86400000);
    totalAmount = nights * pricePerNight;
    const eur   = (totalAmount / XOF_TO_EUR).toFixed(2);
    document.getElementById('nightsCount').textContent      = nights;
    document.getElementById('priceLineTotal').textContent   = totalAmount.toLocaleString('fr-FR') + ' FCFA';
    document.getElementById('totalPriceDisplay').textContent = totalAmount.toLocaleString('fr-FR') + ' FCFA';
    document.getElementById('priceEur').textContent          = '≈ ' + eur + ' EUR';
    document.getElementById('priceBreakdown').style.display  = 'block';
  }
  checkinEl.addEventListener('change',  () => { checkoutEl.min = checkinEl.value; updatePrice(); });
  checkoutEl.addEventListener('change', updatePrice);

  function validate() {
    const errEl = document.getElementById('formError');
    if (!checkinEl.value || !checkoutEl.value || checkoutEl.value <= checkinEl.value) {
      errEl.textContent = 'Veuillez sélectionner des dates valides.'; errEl.style.display = 'block'; return false;
    }
    if (!document.getElementById('fullname').value.trim()) {
      errEl.textContent = 'Veuillez saisir votre nom.'; errEl.style.display = 'block'; return false;
    }
    errEl.style.display = 'none';
    return true;
  }

  function proceedToPayment() {
    if (!validate()) return;
    document.getElementById('recapDates').textContent =
      checkinEl.value + ' → ' + checkoutEl.value + ' (' + nights + ' nuit' + (nights > 1 ? 's' : '') + ')';
    document.getElementById('recapTotal').textContent = totalAmount.toLocaleString('fr-FR') + ' FCFA';
    document.getElementById('stepForm').style.display    = 'none';
    document.getElementById('stepPayment').style.display = 'block';
    initPayPal();
  }
  function backToForm() {
    document.getElementById('stepForm').style.display    = 'block';
    document.getElementById('stepPayment').style.display = 'none';
  }

  function fillFedapay() {
    document.getElementById('fp_checkin').value     = checkinEl.value;
    document.getElementById('fp_checkout').value    = checkoutEl.value;
    document.getElementById('fp_fullname').value    = document.getElementById('fullname').value;
    document.getElementById('fp_phone').value       = document.getElementById('phone').value;
    document.getElementById('fp_email').value       = document.getElementById('email').value;
    document.getElementById('fp_guests').value      = document.getElementById('guests').value;
    document.getElementById('fp_nights').value      = nights;
    document.getElementById('fp_totalAmount').value = totalAmount;
    return true;
  }

  let paypalInited = false;
  function initPayPal() {
    if (paypalInited || typeof paypal === 'undefined') return;
    paypalInited = true;
    paypal.Buttons({
      createOrder: async () => {
        const amountEur = (totalAmount / XOF_TO_EUR).toFixed(2);
        const res = await fetch('/payment/paypal/create-order', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ amountEur })
        });
        const data = await res.json();
        return data.id;
      },
      onApprove: async (data) => {
        const res = await fetch('/payment/paypal/capture', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            orderID: data.orderID, room: '<%= room.name %>', roomId: '<%= room.id %>',
            checkin: checkinEl.value, checkout: checkoutEl.value,
            fullname: document.getElementById('fullname').value, phone: document.getElementById('phone').value,
            email: document.getElementById('email').value, guests: document.getElementById('guests').value,
            nights, totalAmount
          })
        });
        const result = await res.json();
        if (result.success) window.location = '/payment/success?method=paypal';
        else alert('Erreur lors de la confirmation. Contactez-nous.');
      },
      onError: (err) => { console.error(err); alert('Erreur PayPal. Essayez FedaPay ou appelez-nous.'); }
    }).render('#paypal-button-container');
  }

  function copyLink() { navigator.clipboard.writeText(window.location.href).then(() => alert('Lien copié !')); }
</script>
</body>
</html>
