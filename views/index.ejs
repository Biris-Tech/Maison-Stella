<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= settings.siteName %> – <%= settings.tagline %></title>
  <meta name="description" content="<%= settings.description.substring(0,160) %>">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= canonical %>">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:locale" content="fr_FR">
  <meta property="og:site_name" content="<%= settings.siteName %>">
  <meta property="og:title" content="<%= settings.siteName %> – <%= settings.tagline %>">
  <meta property="og:description" content="<%= settings.description.substring(0,200) %>">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:image" content="<%= baseUrl %>/image/<%= encodeURIComponent(settings.heroImage) %>">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= settings.siteName %> – <%= settings.tagline %>">
  <meta name="twitter:description" content="<%= settings.description.substring(0,200) %>">
  <meta name="twitter:image" content="<%= baseUrl %>/image/<%= encodeURIComponent(settings.heroImage) %>">

  <!-- JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LodgingBusiness",
    "name": "<%= settings.siteName %>",
    "description": "<%= settings.description.replace(/"/g,'&quot;') %>",
    "url": "<%= baseUrl %>",
    "address": { "@type": "PostalAddress", "addressLocality": "Lomé", "addressCountry": "TG", "streetAddress": "<%= settings.address.replace(/"/g,'&quot;') %>" },
    "telephone": "<%= settings.phone %>",
    "email": "<%= settings.email %>",
    "image": "<%= baseUrl %>/image/<%= encodeURIComponent(settings.heroImage) %>",
    "priceRange": "$$"
  }
  </script>

  <script>document.documentElement.classList.add('js');</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="preload" as="image" href="/image/<%= encodeURIComponent(settings.heroImage) %>">
  <link rel="stylesheet" href="/css/home.css">
  <link rel="icon" href="/image/logo.png" type="image/png">
</head>
<body>

<!-- NAV -->
<nav class="nav" id="nav">
  <div class="nav-in">
    <a href="/" class="brand">Maison&nbsp;<b>Stella</b><span class="dot">.</span></a>
    <div class="nav-links">
      <a href="#maison">La maison</a>
      <a href="#chambres">Chambres</a>
      <a href="#experience">L'expérience</a>
      <a href="#contact">Contact</a>
    </div>
    <a href="#booking" class="nav-cta">Réserver</a>
  </div>
</nav>

<!-- HERO -->
<header class="hero">
  <div class="wrap">
    <div class="hero-grid">
      <div>
        <p class="label reveal">Avepozo · Lomé, Togo</p>
        <h1 class="reveal">Une parenthèse d'exception au bord du <em class="accent">lac</em>.</h1>
        <p class="hero-sub reveal"><%= settings.description %></p>
      </div>
      <div class="hero-photo reveal">
        <img src="/image/<%= encodeURIComponent(settings.heroImage) %>" alt="<%= settings.siteName %>, Avepozo">
        <span class="cap">Au bord du lac, Avepozo</span>
      </div>
    </div>

    <form class="booking reveal" id="booking" action="/chambres" method="get">
      <div class="f">
        <label for="heroCheckin">Arrivée</label>
        <input type="date" name="checkin" id="heroCheckin">
      </div>
      <div class="f">
        <label for="heroCheckout">Départ</label>
        <input type="date" name="checkout" id="heroCheckout">
      </div>
      <div class="f">
        <label for="heroGuests">Voyageurs</label>
        <select name="guests" id="heroGuests">
          <option value="1">1 personne</option>
          <option value="2" selected>2 personnes</option>
          <option value="3">3 personnes</option>
          <option value="4">4 personnes</option>
        </select>
      </div>
      <button type="submit">Vérifier les disponibilités</button>
    </form>
  </div>
</header>

<!-- LA MAISON -->
<section class="section maison" id="maison">
  <div class="wrap">
    <div class="maison-grid">
      <div class="maison-photo reveal">
        <img src="/image/IMG_0475%20Large.jpeg" alt="Intérieur de Maison Stella" loading="lazy">
      </div>
      <div>
        <p class="label kicker reveal">La maison</p>
        <h2 class="reveal">Reçu comme un hôte,<br>pas logé comme un client.</h2>
        <p class="lead reveal"><%= settings.aboutText %></p>
        <p class="reveal"><%= settings.aboutText2 %></p>
        <a href="/chambres" class="more reveal">Découvrir nos chambres →</a>
      </div>
    </div>
  </div>
</section>

<!-- CHAMBRES -->
<section class="section" id="chambres">
  <div class="wrap">
    <div class="ch-head">
      <div>
        <p class="label kicker reveal">Nos hébergements</p>
        <h2 class="reveal">Chambres &amp; <em>suites</em></h2>
      </div>
      <a href="/chambres" class="ch-link reveal">Voir toutes les chambres <span>→</span></a>
    </div>

    <% if (featured && featured.length) { %>
    <div class="ch-grid">
      <% featured.forEach(room => { %>
      <a href="/chambre/<%= room.id %>" class="room reveal">
        <div class="room-photo">
          <img src="/image/<%= encodeURIComponent(room.images[0]) %>" alt="<%= room.name %>" loading="lazy">
          <% if (room.badge) { %><span class="room-tag"><%= room.badge %></span><% } %>
        </div>
        <div class="room-body">
          <div>
            <h3><%= room.name %></h3>
            <p class="room-meta"><%= room.bedType %> · <%= room.capacity %> voyageurs</p>
          </div>
          <div class="room-price"><strong><%= room.price.toLocaleString('fr-FR') %></strong><small>FCFA / nuit</small></div>
        </div>
      </a>
      <% }) %>
    </div>
    <% } else { %>
    <div class="ch-empty reveal">
      <h3>Nos chambres arrivent très bientôt</h3>
      <p>Contactez-nous dès maintenant pour connaître nos disponibilités et réserver votre séjour.</p>
      <a href="tel:<%= settings.phone.replace(/\s/g,'') %>" class="btn btn-p">Nous appeler</a>
    </div>
    <% } %>
  </div>
</section>

<!-- L'EXPÉRIENCE -->
<section class="section exp" id="experience">
  <div class="wrap">
    <div class="exp-top">
      <p class="label reveal">L'art de bien recevoir</p>
      <h2 class="reveal">Tout est déjà prévu.</h2>
      <p class="reveal">On ne vous vend pas des équipements. On vous offre la tranquillité de n'avoir à penser à rien.</p>
    </div>
    <div class="exp-list">
      <% settings.services.forEach(s => { %>
      <div class="exp-item reveal">
        <span class="exp-ic" aria-hidden="true"><%= s.icon %></span>
        <div>
          <h4><%= s.title %></h4>
          <p><%= s.desc %></p>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section cta">
  <div class="wrap">
    <p class="label reveal">Réservation</p>
    <h2 class="reveal">Votre séjour à <em class="accent"><%= settings.siteName %></em>.</h2>
    <p class="reveal">Confirmation immédiate, paiement sécurisé, et une équipe qui vous répond en quelques minutes — à toute heure.</p>
    <div class="cta-row reveal">
      <a href="#chambres" class="btn btn-p">Réserver une chambre</a>
      <a href="tel:<%= settings.phone.replace(/\s/g,'') %>" class="btn btn-o"><%= settings.phone %></a>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section class="section contact" id="contact">
  <div class="wrap">
    <div class="contact-grid">
      <div>
        <p class="label reveal">Contactez-nous</p>
        <h2 class="reveal">Prenons contact.</h2>
        <p class="intro reveal">Pour toute demande de réservation ou renseignement, notre équipe est disponible 7j/7.</p>
        <div class="contact-list reveal">
          <div class="contact-item">
            <span class="ci"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
            <div><strong>Adresse</strong><br><span><%= settings.address %></span></div>
          </div>
          <div class="contact-item">
            <span class="ci"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 6.29 6.29l1.69-1.84a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 15.7z"/></svg></span>
            <div><strong>Téléphone / WhatsApp</strong><br><a href="tel:<%= settings.phone.replace(/\s/g,'') %>"><%= settings.phone %></a></div>
          </div>
          <div class="contact-item">
            <span class="ci"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
            <div><strong>Horaires</strong><br><span>Ouvert 24h/24 · 7j/7</span></div>
          </div>
        </div>
      </div>
      <div class="contact-card reveal">
        <h3>Envoyer un message</h3>
        <div class="contact-ok" id="contactSuccess"><strong>Message envoyé !</strong> Nous vous répondrons très bientôt.</div>
        <form id="contactForm">
          <div class="form-row">
            <div class="field"><label for="cFirst">Prénom</label><input type="text" id="cFirst" name="firstname" placeholder="Votre prénom" required></div>
            <div class="field"><label for="cLast">Nom</label><input type="text" id="cLast" name="lastname" placeholder="Votre nom" required></div>
          </div>
          <div class="field"><label for="cPhone">Téléphone</label><input type="tel" id="cPhone" name="phone" placeholder="+228 XX XX XX XX"></div>
          <div class="field"><label for="cMsg">Message</label><textarea id="cMsg" name="message" rows="4" placeholder="Votre message…" required></textarea></div>
          <button class="btn btn-p btn-full" type="submit" id="contactBtn">Envoyer le message</button>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="wrap">
    <div class="foot-word reveal">Restez une nuit,<br>repartez <em>ailleurs</em>.</div>
    <div class="foot-grid">
      <div class="foot-brand">
        <a href="/" class="brand">Maison&nbsp;<b>Stella</b><span class="dot">.</span></a>
        <p><%= settings.tagline %> — Avepozo, au bord du lac, Lomé (Togo).</p>
      </div>
      <div class="foot-col">
        <h5>Naviguer</h5>
        <a href="#maison">La maison</a>
        <a href="#chambres">Chambres</a>
        <a href="#experience">L'expérience</a>
        <a href="/chambres">Réserver</a>
      </div>
      <div class="foot-col">
        <h5>Nous trouver</h5>
        <p><%= settings.address %></p>
        <a href="tel:<%= settings.phone.replace(/\s/g,'') %>"><%= settings.phone %></a>
        <a href="https://www.airbnb.fr/users/profile/1470333770914956183" target="_blank" rel="noopener">Airbnb</a>
        <a href="https://www.instagram.com/maisonstellalome/" target="_blank" rel="noopener">Instagram</a>
        <a href="https://www.tiktok.com/@maisonstellalome" target="_blank" rel="noopener">TikTok</a>
      </div>
    </div>
    <div class="foot-bot">
      <span>© <%= new Date().getFullYear() %> <%= settings.siteName %></span>
      <span>Avepozo · Lomé · Togo</span>
    </div>
  </div>
</footer>

<script>
  // reveals
  (function(){
    var io = new IntersectionObserver(function(es){ es.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } }); }, {threshold: .12, rootMargin: '0px 0px -6% 0px'});
    document.querySelectorAll('.reveal').forEach(function(el){ io.observe(el); });
  })();
  // nav sticky
  (function(){
    var nav = document.getElementById('nav');
    window.addEventListener('scroll', function(){ nav.classList.toggle('stuck', window.scrollY > window.innerHeight * 0.7); }, {passive:true});
  })();
  // date minimum
  (function(){
    var ci = document.getElementById('heroCheckin'), co = document.getElementById('heroCheckout');
    var today = new Date().toISOString().split('T')[0];
    ci.min = today; co.min = today;
    ci.addEventListener('change', function(){ co.min = this.value; });
  })();
  // contact form
  document.getElementById('contactForm').addEventListener('submit', async function(e){
    e.preventDefault();
    var btn = document.getElementById('contactBtn');
    btn.disabled = true; btn.textContent = 'Envoi…';
    try {
      var fd = new FormData(this);
      var resp = await fetch('/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(Object.fromEntries(fd)) });
      if (!resp.ok) throw new Error();
      this.style.display = 'none';
      document.getElementById('contactSuccess').style.display = 'block';
    } catch {
      btn.disabled = false; btn.textContent = 'Envoyer le message';
      alert('Une erreur est survenue, veuillez réessayer.');
    }
  });
</script>
</body>
</html>
