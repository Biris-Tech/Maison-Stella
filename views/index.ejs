<%
  title = 'Accueil';
  body = '';
%>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= settings.siteName %> – <%= settings.tagline %></title>
  <meta name="description" content="<%= settings.description.substring(0,160) %>">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= canonical %>">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:locale" content="fr_FR">
  <meta property="og:site_name" content="<%= settings.siteName %>">
  <meta property="og:title" content="<%= settings.siteName %> – <%= settings.tagline %>">
  <meta property="og:description" content="<%= settings.description.substring(0,200) %>">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:image" content="<%= baseUrl %>/image/<%= encodeURIComponent(settings.heroImage) %>">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= settings.siteName %> – <%= settings.tagline %>">
  <meta name="twitter:description" content="<%= settings.description.substring(0,200) %>">
  <meta name="twitter:image" content="<%= baseUrl %>/image/<%= encodeURIComponent(settings.heroImage) %>">

  <!-- JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LodgingBusiness",
    "name": "<%= settings.siteName %>",
    "description": "<%= settings.description.replace(/"/g,'&quot;') %>",
    "url": "<%= baseUrl %>",
    "address": { "@type": "PostalAddress", "addressLocality": "Lomé", "addressCountry": "TG", "streetAddress": "<%= settings.address.replace(/"/g,'&quot;') %>" },
    "telephone": "<%= settings.phone %>",
    "email": "<%= settings.email %>",
    "image": "<%= baseUrl %>/image/<%= encodeURIComponent(settings.heroImage) %>",
    "priceRange": "$$"
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="preload" as="image" href="/image/<%= encodeURIComponent(settings.heroImage) %>">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="icon" href="/image/logo.png" type="image/png">
</head>
<body>

<div id="preloader">
  <div class="preloader-inner">
    <img src="/image/logo.png" alt="<%= settings.siteName %>" class="preloader-logo" width="72" height="72">
    <div class="preloader-bar"><div class="preloader-bar-inner"></div></div>
  </div>
</div>

<%- include('partials/nav', { page, settings }) %>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg" style="background-image: url('/image/<%= encodeURIComponent(settings.heroImage) %>')"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <p class="hero-eyebrow">Avepozo · Lomé, Togo</p>
    <h1>Bienvenue à<br><span class="hero-name"><%= settings.siteName %></span></h1>
    <p class="hero-sub"><%= settings.description %></p>
    <div class="hero-search">
      <form class="search-bar" action="/chambres" method="get">
        <div class="search-field">
          <label>Arrivée</label>
          <input type="date" name="checkin" id="heroCheckin">
        </div>
        <div class="search-divider"></div>
        <div class="search-field">
          <label>Départ</label>
          <input type="date" name="checkout" id="heroCheckout">
        </div>
        <div class="search-divider"></div>
        <div class="search-field">
          <label>Voyageurs</label>
          <select name="guests">
            <option value="1">1 personne</option>
            <option value="2" selected>2 personnes</option>
            <option value="3">3 personnes</option>
            <option value="4">4 personnes</option>
          </select>
        </div>
        <button type="submit" class="search-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          Chercher
        </button>
      </form>
    </div>
  </div>
</section>

<!-- STATS STRIP -->
<div class="stats-strip">
  <div class="stat-item"><strong>7</strong><span>Chambres & suites</span></div>
  <div class="stat-item"><strong>1</strong><span>Piscine privée</span></div>
  <div class="stat-item"><strong>24/7</strong><span>Service disponible</span></div>
  <div class="stat-item"><strong>5★</strong><span>Expérience premium</span></div>
</div>

<!-- ABOUT -->
<section class="section" id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-images">
        <div class="about-img-main">
          <img src="/image/<%= encodeURIComponent(settings.heroImage) %>" alt="<%= settings.siteName %>" loading="lazy">
        </div>
        <div class="about-img-accent">
          <img src="/image/IMG_0499%20Large.jpeg" alt="Détail" loading="lazy">
        </div>
      </div>
      <div class="about-text">
        <p class="eyebrow">Notre histoire</p>
        <h2>Un lieu d'exception<br>à <span class="text-primary">Avepozo</span></h2>
        <p class="body-text"><%= settings.aboutText %></p>
        <p class="body-text"><%= settings.aboutText2 %></p>
        <a href="/chambres" class="btn-primary" style="margin-top: 1.5rem; display: inline-flex; align-items: center; gap: 0.5rem;">
          Découvrir nos chambres →
        </a>
      </div>
    </div>
  </div>
</section>

<!-- FEATURED ROOMS -->
<section class="section section-gray" id="chambres-preview">
  <div class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow">Nos hébergements</p>
        <h2>Chambres & <span class="text-primary">Suites</span></h2>
      </div>
      <a href="/chambres" class="btn-outline">Tout voir</a>
    </div>
    <div class="rooms-grid">
      <% featured.forEach(room => { %>
      <a href="/chambre/<%= room.id %>" class="room-card">
        <div class="room-card-img">
          <img src="/image/<%= encodeURIComponent(room.images[0]) %>" alt="<%= room.name %>" loading="lazy">
          <% if (room.badge) { %>
          <span class="room-badge"><%= room.badge %></span>
          <% } %>
        </div>
        <div class="room-card-body">
          <div class="room-card-top">
            <h3 class="room-card-name"><%= room.name %></h3>
            <div class="room-card-rating"><svg width="13" height="13" viewBox="0 0 24 24" fill="#f59e0b" stroke="#f59e0b" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> 4.9</div>
          </div>
          <p class="room-card-meta"><%= room.bedType %> · <%= room.capacity %> pers.</p>
          <p class="room-card-desc"><%= room.desc.substring(0, 90) %>…</p>
          <div class="room-card-footer">
            <div class="room-card-price">
              <strong><%= room.price.toLocaleString('fr-FR') %></strong>
              <span>FCFA / nuit</span>
            </div>
            <span class="room-card-link">Voir →</span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- SOCIAL STRIP -->
<div class="social-strip">
  <div class="container">
    <div class="social-strip-inner">
      <div class="social-strip-text">
        <span>Retrouvez-nous sur</span>
      </div>
      <div class="social-strip-links">
        <a href="https://www.airbnb.fr/users/profile/1470333770914956183?previous_page_name=PdpHomeMarketplace"
           target="_blank" rel="noopener" class="social-strip-btn airbnb-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.003 0C5.374 0 0 5.373 0 12.003S5.374 24 12.003 24 24 18.626 24 12.003 18.626 0 12.003 0zm0 4.5c1.18 0 2.134.954 2.134 2.133 0 1.18-.954 2.134-2.134 2.134-1.179 0-2.133-.954-2.133-2.134 0-1.179.954-2.133 2.133-2.133zm5.4 13.364c-.09.207-.27.34-.47.34H7.07c-.2 0-.38-.133-.47-.34-.09-.207-.05-.44.1-.607l2.52-2.76c.15-.165.37-.24.59-.2l1.25.25.94-5.5c.055-.32.33-.547.655-.547s.6.227.655.547l.94 5.5 1.25-.25c.22-.04.44.035.59.2l2.52 2.76c.15.167.19.4.1.607z"/></svg>
          Réserver sur Airbnb
        </a>
        <a href="https://www.instagram.com/maisonstellalome/"
           target="_blank" rel="noopener" class="social-strip-btn instagram-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          @maisonstellalome
        </a>
        <a href="https://www.tiktok.com/@maisonstellalome"
           target="_blank" rel="noopener" class="social-strip-btn tiktok-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.27 8.27 0 004.84 1.56V6.79a4.85 4.85 0 01-1.07-.1z"/></svg>
          @maisonstellalome
        </a>
      </div>
    </div>
  </div>
</div>

<!-- SERVICES -->
<section class="section" id="services">
  <div class="container">
    <div class="section-head-center">
      <p class="eyebrow">Ce que nous offrons</p>
      <h2>Tout pour votre <span class="text-primary">confort</span></h2>
    </div>
    <div class="services-grid">
      <% settings.services.forEach(s => { %>
      <div class="service-card">
        <div class="service-icon"><%= s.icon %></div>
        <h3 class="service-title"><%= s.title %></h3>
        <p class="service-desc"><%= s.desc %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- CTA BANNER -->
<section class="cta-section">
  <div class="container">
    <div class="cta-inner">
      <div>
        <h2>Prêt à vivre l'expérience<br><span class="text-primary"><%= settings.siteName %></span> ?</h2>
        <p>Réservez votre chambre dès maintenant et profitez d'un séjour inoubliable.</p>
      </div>
      <div class="cta-actions">
        <a href="/chambres" class="btn-primary btn-lg">Voir les chambres</a>
        <a href="tel:<%= settings.phone.replace(/\s/g,'') %>" class="btn-outline btn-lg">Nous appeler</a>
      </div>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section class="section" id="contact">
  <div class="container">
    <div class="contact-grid">
      <div>
        <p class="eyebrow">Contactez-nous</p>
        <h2>Prenons <span class="text-primary">contact</span></h2>
        <p class="body-text">Pour toute demande de réservation ou renseignement, notre équipe est disponible 7j/7.</p>
        <div class="contact-list">
          <div class="contact-item">
            <div class="contact-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
            <div><strong>Adresse</strong><br><%= settings.address %></div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 6.29 6.29l1.69-1.84a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 15.7v1.22z"/></svg></div>
            <div><strong>Téléphone / WhatsApp</strong><br><a href="tel:<%= settings.phone.replace(/\s/g,'') %>"><%= settings.phone %></a></div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
            <div><strong>Horaires</strong><br>Ouvert 24h/24 · 7j/7</div>
          </div>
        </div>
      </div>
      <div class="contact-form-wrap">
        <h3>Envoyer un message</h3>
        <form class="contact-form" id="contactForm">
          <div class="form-row">
            <div class="field"><label>Prénom</label><input type="text" placeholder="Votre prénom" required></div>
            <div class="field"><label>Nom</label><input type="text" placeholder="Votre nom" required></div>
          </div>
          <div class="field"><label>Téléphone</label><input type="tel" placeholder="+228 XX XX XX XX"></div>
          <div class="field"><label>Message</label><textarea rows="4" placeholder="Votre message…" required></textarea></div>
          <button class="btn-primary btn-full" type="submit">Envoyer le message</button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer', { settings }) %>

<script src="/js/main.js"></script>
<script>
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('heroCheckin').min = today;
  document.getElementById('heroCheckin').addEventListener('change', function() {
    document.getElementById('heroCheckout').min = this.value;
  });
  document.getElementById('contactForm').addEventListener('submit', function(e) {
    e.preventDefault();
    alert('Message envoyé ✅\nNous vous répondrons très bientôt.');
    this.reset();
  });
  window.addEventListener('load', () => { const p = document.getElementById('preloader'); if (p) p.classList.add('fade-out'); });
</script>
</body>
</html>
