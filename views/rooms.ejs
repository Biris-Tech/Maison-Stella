<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nos Chambres & Suites – <%= settings.siteName %></title>
  <meta name="description" content="Découvrez toutes les chambres et suites de <%= settings.siteName %> à Avepozo, Lomé. Réservation en ligne, paiement sécurisé.">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= canonical %>">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="fr_FR">
  <meta property="og:title" content="Nos Chambres & Suites – <%= settings.siteName %>">
  <meta property="og:description" content="Découvrez toutes les chambres et suites de <%= settings.siteName %> à Avepozo, Lomé.">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:image" content="<%= baseUrl %>/image/<%= encodeURIComponent(settings.heroImage) %>">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Nos Chambres – <%= settings.siteName %>">
  <meta name="twitter:image" content="<%= baseUrl %>/image/<%= encodeURIComponent(settings.heroImage) %>">
  <script>document.documentElement.classList.add('js');</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/home.css">
  <link rel="icon" href="/image/logo.png" type="image/png">
</head>
<body>

<%- include('partials/site-nav', { settings }) %>

<header class="page-head">
  <div class="wrap">
    <p class="breadcrumb reveal"><a href="/">Accueil</a> · Nos chambres</p>
    <h1 class="reveal">Chambres &amp; <em>suites</em></h1>
    <p class="sub reveal">Tarifs par nuit · petit-déjeuner selon disponibilité · réservation en quelques minutes.</p>
  </div>
</header>

<section style="padding-bottom: clamp(4rem, 9vw, 8rem)">
  <div class="wrap">
    <div class="filter-bar reveal">
      <span class="filter-count"><%= rooms.length %> logement<%= rooms.length > 1 ? 's' : '' %></span>
      <div class="chips">
        <button class="chip active" data-filter="all">Tous</button>
        <button class="chip" data-filter="2">2 voyageurs</button>
        <button class="chip" data-filter="3">3 voyageurs</button>
        <button class="chip" data-filter="4">4 voyageurs</button>
      </div>
    </div>

    <% if (rooms && rooms.length) { %>
    <div class="ch-grid" id="roomsGrid">
      <% rooms.forEach(room => { %>
      <a href="/chambre/<%= room.id %>" class="room reveal" data-capacity="<%= room.capacity %>">
        <div class="room-photo">
          <img src="/image/<%= encodeURIComponent(room.images[0]) %>" alt="<%= room.name %>" loading="lazy">
          <% if (room.badge) { %><span class="room-tag"><%= room.badge %></span><% } %>
        </div>
        <div class="room-body">
          <div>
            <h3><%= room.name %></h3>
            <p class="room-meta"><%= room.bedType %> · <%= room.capacity %> voyageurs</p>
          </div>
          <div class="room-price"><strong><%= room.price.toLocaleString('fr-FR') %></strong><small>FCFA / nuit</small></div>
        </div>
      </a>
      <% }) %>
    </div>
    <% } else { %>
    <div class="ch-empty reveal">
      <h3>Nos chambres arrivent très bientôt</h3>
      <p>Contactez-nous dès maintenant pour connaître nos disponibilités et réserver votre séjour.</p>
      <a href="tel:<%= settings.phone.replace(/\s/g,'') %>" class="btn btn-p">Nous appeler</a>
    </div>
    <% } %>
  </div>
</section>

<%- include('partials/site-footer', { settings }) %>

<script src="/js/site.js"></script>
<script>
  document.querySelectorAll('.chip').forEach(function (chip) {
    chip.addEventListener('click', function () {
      document.querySelectorAll('.chip').forEach(function (c) { c.classList.remove('active'); });
      this.classList.add('active');
      var f = this.dataset.filter;
      document.querySelectorAll('.room').forEach(function (card) {
        card.style.display = (f === 'all' || Number(card.dataset.capacity) >= Number(f)) ? '' : 'none';
      });
    });
  });
</script>
</body>
</html>
