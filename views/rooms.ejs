<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nos Chambres – <%= settings.siteName %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>

<%- include('partials/nav', { page, settings }) %>

<div class="page-hero-sm">
  <div class="container">
    <p class="breadcrumb"><a href="/">Accueil</a> / Nos chambres</p>
    <h1>Nos Chambres & <span class="text-primary">Suites</span></h1>
    <p class="page-hero-sub">Tarifs par nuit · Petit-déjeuner inclus selon disponibilité</p>
  </div>
</div>

<div class="container" style="padding-top: 2rem; padding-bottom: 5rem;">
  <div class="filter-bar">
    <span class="filter-count"><%= rooms.length %> logement<%= rooms.length > 1 ? 's' : '' %></span>
    <div class="filter-chips">
      <button class="chip active" data-filter="all">Tous</button>
      <button class="chip" data-filter="2">2 pers.</button>
      <button class="chip" data-filter="3">3 pers.</button>
      <button class="chip" data-filter="4">4 pers.</button>
    </div>
  </div>

  <div class="rooms-grid-full" id="roomsGrid">
    <% rooms.forEach(room => { %>
    <a href="/chambre/<%= room.id %>" class="room-card" data-capacity="<%= room.capacity %>">
      <div class="room-card-img">
        <img src="/image/<%= encodeURIComponent(room.images[0]) %>" alt="<%= room.name %>" loading="lazy">
        <% if (room.badge) { %>
        <span class="room-badge"><%= room.badge %></span>
        <% } %>
        <button class="room-wishlist" onclick="event.preventDefault(); this.classList.toggle('active')" title="Favori">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </button>
      </div>
      <div class="room-card-body">
        <div class="room-card-top">
          <h3 class="room-card-name"><%= room.name %></h3>
          <div class="room-card-rating">⭐ 4.9</div>
        </div>
        <p class="room-card-meta"><%= room.bedType %> · <%= room.capacity %> pers. max</p>
        <p class="room-card-desc"><%= room.desc.substring(0, 100) %>…</p>
        <div class="room-card-amenities">
          <% room.amenities.slice(0, 3).forEach(a => { %><span class="amenity-tag"><%= a %></span><% }) %>
        </div>
        <div class="room-card-footer">
          <div class="room-card-price">
            <strong><%= room.price.toLocaleString('fr-FR') %></strong>
            <span>FCFA / nuit</span>
          </div>
          <span class="room-card-link">Réserver →</span>
        </div>
      </div>
    </a>
    <% }) %>
  </div>
</div>

<%- include('partials/footer', { settings }) %>
<script src="/js/main.js"></script>
<script>
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', function() {
      document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
      this.classList.add('active');
      const filter = this.dataset.filter;
      document.querySelectorAll('.room-card').forEach(card => {
        card.style.display = (filter === 'all' || card.dataset.capacity >= filter) ? '' : 'none';
      });
    });
  });
</script>
</body>
</html>
