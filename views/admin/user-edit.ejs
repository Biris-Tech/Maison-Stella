<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin – Modifier <%= user.name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="icon" href="/image/logo.png" type="image/png">
</head>
<body class="admin-body">

<%- include('sidebar', { activePage: 'users', settings }) %>

<main class="admin-main">
  <div class="admin-topbar">
    <div style="display:flex;align-items:center;gap:0.75rem;">
      <a href="/admin/utilisateurs" class="topbar-back">← Utilisateurs</a>
      <span class="topbar-sep">/</span>
      <h1 class="admin-page-title"><%= user.name %></h1>
    </div>
  </div>
  <div class="admin-content">

    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <% if (req.query.success) { %><div class="alert alert-success"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:0.4rem"><polyline points="20 6 9 17 4 12"/></svg> Modifications enregistrées.</div><% } %>

    <form method="POST" action="/admin/utilisateurs/update/<%= user.id %>" class="settings-form">
      <div class="settings-card">
        <h2 class="settings-section-title">Informations</h2>
        <div class="settings-grid">
          <div class="field">
            <label>Nom complet</label>
            <input type="text" name="name" value="<%= user.name %>" required>
          </div>
          <div class="field">
            <label>Adresse e-mail</label>
            <input type="email" name="email" value="<%= user.email %>" required>
          </div>
          <div class="field">
            <label>Nouveau mot de passe</label>
            <input type="password" name="password" placeholder="Laisser vide pour ne pas changer">
          </div>
          <div class="field">
            <label>Rôle</label>
            <select name="role">
              <option value="writer" <%= user.role === 'writer' ? 'selected' : '' %>>Rédacteur</option>
              <option value="editor" <%= user.role === 'editor' ? 'selected' : '' %>>Éditeur</option>
              <option value="superadmin" <%= user.role === 'superadmin' ? 'selected' : '' %>>Super Admin</option>
            </select>
          </div>
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn-admin-primary btn-lg">Enregistrer</button>
        <a href="/admin/utilisateurs" class="btn-admin-outline btn-lg">Retour</a>
      </div>
    </form>

  </div>
</main>
<script src="/js/admin.js"></script>
</body>
</html>
