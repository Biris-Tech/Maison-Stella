<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin – Tableau de bord</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="icon" href="/image/logo.png" type="image/png">
</head>
<body class="admin-body">

<%- include('sidebar', { activePage: 'dashboard', settings }) %>

<main class="admin-main">
  <div class="admin-topbar">
    <h1 class="admin-page-title">Tableau de bord</h1>
    <a href="/" target="_blank" class="btn-admin-outline btn-sm">Voir le site →</a>
  </div>
  <div class="admin-content">

    <div class="stats-cards">
      <div class="stat-card">
        <div class="stat-card-icon" style="background: #fff0f0; color: #FF385C;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
        <div>
          <div class="stat-card-num"><%= stats.totalRooms %></div>
          <div class="stat-card-label">Chambres actives</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-card-icon" style="background: #f0f7ff; color: #0066cc;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
        <div>
          <div class="stat-card-num"><%= stats.totalBookings %></div>
          <div class="stat-card-label">Total réservations</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-card-icon" style="background: #fffbf0; color: #e6a000;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
        <div>
          <div class="stat-card-num"><%= stats.pendingBookings %></div>
          <div class="stat-card-label">En attente</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-card-icon" style="background: #f0fff4; color: #00aa44;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
        <div>
          <div class="stat-card-num"><%= stats.confirmedBookings %></div>
          <div class="stat-card-label">Confirmées</div>
        </div>
      </div>
    </div>

    <div class="admin-section-title">Dernières réservations</div>

    <% if (bookings.length === 0) { %>
    <div class="empty-state">
      <p>Aucune réservation pour l'instant.</p>
      <a href="/chambres" target="_blank" class="btn-admin-primary">Voir les chambres →</a>
    </div>
    <% } else { %>
    <div class="table-wrap">
      <table class="admin-table">
        <thead>
          <tr><th>Client</th><th>Chambre</th><th>Arrivée</th><th>Départ</th><th>Téléphone</th><th>Statut</th><th>Action</th></tr>
        </thead>
        <tbody>
          <% bookings.forEach(b => { %>
          <tr>
            <td><strong><%= b.fullname || '—' %></strong></td>
            <td><%= b.room %></td>
            <td><%= b.checkin %></td>
            <td><%= b.checkout %></td>
            <td><%= b.phone || '—' %></td>
            <td>
              <span class="status-badge status-<%= b.status %>">
                <%= b.status === 'pending' ? 'En attente' : b.status === 'confirmed' ? 'Confirmée' : 'Annulée' %>
              </span>
            </td>
            <td>
              <form method="POST" action="/admin/reservations/status/<%= b.id %>" style="display:inline">
                <input type="hidden" name="status" value="confirmed">
                <button type="submit" class="btn-xs btn-green" title="Confirmer">✓</button>
              </form>
              <form method="POST" action="/admin/reservations/status/<%= b.id %>" style="display:inline">
                <input type="hidden" name="status" value="cancelled">
                <button type="submit" class="btn-xs btn-red" title="Annuler">✗</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>

    <div style="margin-top: 1.5rem;">
      <a href="/admin/reservations" class="btn-admin-outline">Voir toutes les réservations →</a>
    </div>

  </div>
</main>

<script src="/js/admin.js"></script>
</body>
</html>
