<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin – Blog</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="icon" href="/image/logo.png" type="image/png">
</head>
<body class="admin-body">

<%- include('sidebar', { activePage: 'blog', settings }) %>

<main class="admin-main">
  <div class="admin-topbar">
    <h1 class="admin-page-title">Articles de blog</h1>
    <a href="/admin/blog/nouveau" class="btn-admin-primary btn-sm">+ Nouvel article</a>
  </div>
  <div class="admin-content">

    <% if (success) { %><div class="alert alert-success"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:0.4rem"><polyline points="20 6 9 17 4 12"/></svg> <%= success %></div><% } %>

    <% if (posts.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></div>
      <p>Aucun article pour l'instant.</p>
      <a href="/admin/blog/nouveau" class="btn-admin-primary">Écrire le premier article</a>
    </div>
    <% } else { %>
    <div class="table-wrap">
      <table class="admin-table">
        <thead>
          <tr><th>Titre</th><th>Auteur</th><th>Statut</th><th>Publié le</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% posts.forEach(p => { %>
          <tr>
            <td>
              <strong><%= p.title %></strong>
              <% if (p.tags && p.tags.length) { %>
              <div style="margin-top:0.2rem;">
                <% p.tags.forEach(t => { %><span class="amenity-tag" style="font-size:0.7rem;"><%= t %></span><% }) %>
              </div>
              <% } %>
            </td>
            <td><%= p.authorName %></td>
            <td>
              <span class="status-badge" style="<%= p.status === 'published' ? 'background:#f0fdf4;color:#166534;' : 'background:#f1f5f9;color:#64748b;' %>">
                <%= p.status === 'published' ? 'Publié' : 'Brouillon' %>
              </span>
            </td>
            <td><%= p.publishedAt ? new Date(p.publishedAt).toLocaleDateString('fr-FR') : '—' %></td>
            <td class="actions-cell">
              <% if (p.status === 'published') { %>
              <a href="/blog/<%= p.slug %>" target="_blank" class="btn-xs btn-green">Voir</a>
              <% } %>
              <a href="/admin/blog/edit/<%= p.id %>" class="btn-admin-outline btn-sm">Modifier</a>
              <form method="POST" action="/admin/blog/delete/<%= p.id %>" style="display:inline"
                onsubmit="return confirm('Supprimer cet article ?')">
                <button type="submit" class="btn-xs btn-red">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                </button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>

  </div>
</main>
<script src="/js/admin.js"></script>
</body>
</html>
