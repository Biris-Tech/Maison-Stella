<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin – Connexion</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="icon" href="/image/logo.png" type="image/png">
</head>
<body class="login-page">
  <div class="login-card">
    <div class="login-logo">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
    </div>
    <h1>Administration</h1>
    <p class="login-sub">Maison Stella</p>
    <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
    <% } %>
    <form method="POST" action="/admin/login" class="login-form">
      <div class="field">
        <label>Adresse e-mail</label>
        <input type="email" name="email" placeholder="admin@maisonstella.tg" required autofocus>
      </div>
      <div class="field">
        <label>Mot de passe</label>
        <input type="password" name="password" placeholder="••••••••" required>
      </div>
      <button type="submit" class="btn-admin-primary btn-full">Se connecter</button>
    </form>
    <a href="/" class="back-link">← Retour au site</a>
  </div>
</body>
</html>
