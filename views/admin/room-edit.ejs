<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin – Modifier <%= room.name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">

<%- include('sidebar', { activePage: 'rooms', settings }) %>

<main class="admin-main">
  <div class="admin-topbar">
    <div style="display:flex; align-items:center; gap:0.75rem;">
      <a href="/admin/chambres" class="topbar-back">← Chambres</a>
      <span class="topbar-sep">/</span>
      <h1 class="admin-page-title"><%= room.name %></h1>
    </div>
    <div style="display:flex; gap:0.75rem;">
      <a href="/chambre/<%= room.id %>" target="_blank" class="btn-admin-outline btn-sm">Voir sur le site →</a>
      <form method="POST" action="/admin/chambres/delete/<%= room.id %>" style="display:inline"
        onsubmit="return confirm('Supprimer « <%= room.name %> » ? Cette action est irréversible.')">
        <button type="submit" class="btn-xs btn-red" style="padding:0.5rem 1rem;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:0.25rem"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg> Supprimer</button>
      </form>
    </div>
  </div>

  <div class="admin-content">
    <% if (success) { %><div class="alert alert-success"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:0.3rem"><polyline points="20 6 9 17 4 12"/></svg> <%= success %></div><% } %>
    <% if (error) { %><div class="alert alert-error">❌ <%= error %></div><% } %>

    <div class="edit-page-grid">

      <!-- COLONNE GAUCHE : infos -->
      <div>
        <div class="settings-card">
          <h2 class="settings-section-title">Informations générales</h2>
          <form method="POST" action="/admin/chambres/update/<%= room.id %>">
            <div class="settings-grid">
              <div class="field">
                <label>Nom de la chambre</label>
                <input type="text" name="name" value="<%= room.name %>" required>
              </div>
              <div class="field">
                <label>Prix (FCFA / nuit)</label>
                <input type="number" name="price" value="<%= room.price %>" required>
              </div>
              <div class="field">
                <label>Capacité (personnes)</label>
                <input type="number" name="capacity" value="<%= room.capacity %>" min="1" max="10">
              </div>
              <div class="field">
                <label>Type de lit</label>
                <input type="text" name="bedType" value="<%= room.bedType %>">
              </div>
              <div class="field">
                <label>Badge</label>
                <input type="text" name="badge" value="<%= room.badge %>" placeholder="ex: Populaire, Suite…">
              </div>
              <div class="field" style="align-self:center;">
                <label>
                  <input type="checkbox" name="featured" <%= room.featured ? 'checked' : '' %>>
                  Mettre en vedette sur l'accueil
                </label>
              </div>
              <div class="field field-full">
                <label>Description</label>
                <textarea name="desc" rows="4"><%= room.desc %></textarea>
              </div>
              <div class="field">
                <label>Composition de la chambre</label>
                <textarea name="composition" rows="7"><%= room.composition.join('\n') %></textarea>
                <span class="field-hint">Un élément par ligne</span>
              </div>
              <div class="field">
                <label>Commodités / Services</label>
                <textarea name="amenities" rows="7"><%= room.amenities.join('\n') %></textarea>
                <span class="field-hint">Un élément par ligne</span>
              </div>
            </div>
            <div class="form-actions" style="margin-top:1.5rem;">
              <button type="submit" class="btn-admin-primary btn-lg">Enregistrer les modifications</button>
            </div>
          </form>
        </div>
      </div>

      <!-- COLONNE DROITE : photos + statut -->
      <div style="display:flex; flex-direction:column; gap:1.5rem;">

        <!-- Statut rapide -->
        <div class="settings-card">
          <h2 class="settings-section-title">Statut</h2>
          <div style="display:flex; align-items:center; justify-content:space-between;">
            <span>
              <span class="status-pill <%= room.active ? 'status-active' : 'status-inactive' %>">
                <%= room.active ? 'Chambre active' : 'Chambre inactive' %>
              </span>
              <% if (room.featured) { %>
              <span class="status-pill status-featured" style="margin-left:0.35rem;"><svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" style="vertical-align:middle"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> En vedette</span>
              <% } %>
            </span>
            <form method="POST" action="/admin/chambres/toggle/<%= room.id %>">
              <button type="submit" class="btn-admin-ghost btn-sm">
                <%= room.active ? 'Désactiver' : 'Activer' %>
              </button>
            </form>
          </div>
        </div>

        <!-- Photos existantes -->
        <div class="settings-card">
          <h2 class="settings-section-title">Photos (<%= room.images.length %>)</h2>

          <% if (room.images.length > 0) { %>
          <div class="image-admin-grid" style="grid-template-columns: repeat(3, 1fr);">
            <% room.images.forEach((img, idx) => { %>
            <div class="image-admin-thumb" id="thumb-<%= idx %>">
              <img src="/image/<%= encodeURIComponent(img) %>" alt="Photo <%= idx+1 %>" loading="lazy">
              <!-- État normal -->
              <div class="image-admin-overlay" id="overlay-<%= idx %>">
                <% if (idx === 0) { %><span class="image-main-badge">Principale</span><% } %>
                <button type="button" class="image-delete-btn" onclick="askDelete(<%= idx %>)"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg></button>
              </div>
              <!-- Confirmation inline -->
              <div class="image-confirm" id="confirm-<%= idx %>" style="display:none;">
                <p>Supprimer ?</p>
                <div class="image-confirm-actions">
                  <form method="POST" action="/admin/chambres/<%= room.id %>/images/delete">
                    <input type="hidden" name="image" value="<%= img %>">
                    <button type="submit" class="img-confirm-yes">Oui</button>
                  </form>
                  <button type="button" class="img-confirm-no" onclick="cancelDelete(<%= idx %>)">Non</button>
                </div>
              </div>
            </div>
            <% }) %>
          </div>
          <% } else { %>
          <p style="color:var(--muted); font-size:0.88rem; margin-bottom:1rem;">Aucune photo pour l'instant.</p>
          <% } %>

          <!-- Upload -->
          <form method="POST" action="/admin/chambres/<%= room.id %>/images"
            enctype="multipart/form-data" style="margin-top:1.25rem; border-top:1px solid var(--border); padding-top:1.25rem;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.75rem;">
              <p style="font-size:0.82rem; font-weight:600; color:var(--dark);">Ajouter des photos</p>
              <button type="button" class="btn-admin-ghost btn-sm" onclick="openLibraryModal()">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:0.25rem"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg> Médiathèque
              </button>
            </div>
            <div class="upload-zone" id="uploadZone" style="padding:1.5rem 1rem;">
              <div class="upload-zone-inner">
                <div class="upload-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
                <p style="font-size:0.88rem;"><strong>Glisser</strong> ou cliquer pour choisir</p>
                <input type="file" name="images" id="imgInput" accept="image/*" multiple style="display:none;">
                <button type="button" class="btn-admin-outline btn-sm" style="margin-top:0.5rem;"
                  onclick="document.getElementById('imgInput').click()">Choisir des photos</button>
              </div>
            </div>
            <div class="upload-preview" id="previewGrid" style="grid-template-columns: repeat(3,1fr); margin-top:0.75rem;"></div>
            <button type="submit" class="btn-admin-primary btn-full" style="margin-top:0.75rem;">
              Envoyer les photos
            </button>
          </form>
        </div>

      </div>
    </div>
  </div>
</main>

<!-- Modal médiathèque -->
<div class="modal-backdrop" id="libraryModal" style="display:none;" onclick="closeLibraryModal(event)">
  <div class="modal-box" style="max-width:700px;" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h3>Choisir depuis la médiathèque</h3>
      <button class="modal-close" onclick="closeLibraryModal()">✕</button>
    </div>
    <input type="text" placeholder="Rechercher…" class="media-search-input" style="width:100%;margin-bottom:1rem;" oninput="filterLibrary(this.value)">
    <div class="library-modal-grid" id="libraryGrid">Chargement…</div>
    <div class="modal-actions">
      <span id="libSelCount" style="font-size:0.82rem;color:var(--muted);margin-right:auto;">0 sélectionnée(s)</span>
      <button class="btn-admin-outline" onclick="closeLibraryModal()">Annuler</button>
      <button class="btn-admin-primary" onclick="confirmLibrarySelection()">Ajouter à la chambre</button>
    </div>
  </div>
</div>

<script src="/js/admin.js"></script>
<script>
  /* ── Confirmation inline suppression photo ── */
  function askDelete(idx) {
    document.getElementById('overlay-' + idx).style.display = 'none';
    document.getElementById('confirm-' + idx).style.display = 'flex';
  }
  function cancelDelete(idx) {
    document.getElementById('confirm-' + idx).style.display = 'none';
    document.getElementById('overlay-' + idx).style.display = 'flex';
  }

  /* ── Upload preview + AJAX progressif ── */
  const ROOM_ID   = '<%= room.id %>';
  const input     = document.getElementById('imgInput');
  const preview   = document.getElementById('previewGrid');
  const zone      = document.getElementById('uploadZone');
  const uploadForm = zone.closest('form');
  const submitBtn  = uploadForm.querySelector('button[type="submit"]');

  let previewItems = []; // [{file, div}]

  input.addEventListener('change', showPreviews);

  zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
  zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
  zone.addEventListener('drop', e => {
    e.preventDefault(); zone.classList.remove('drag-over');
    const dt = new DataTransfer();
    [...(input.files || []), ...e.dataTransfer.files].forEach(f => dt.items.add(f));
    input.files = dt.files;
    showPreviews();
  });

  function showPreviews() {
    preview.innerHTML = '';
    previewItems = [];
    [...input.files].forEach(file => {
      const div = document.createElement('div');
      div.className = 'preview-thumb';
      div.innerHTML = `<div style="width:100%;aspect-ratio:1;background:var(--bg);border-radius:8px;border:1px solid var(--border);"></div>
        <div class="preview-progress-wrap"><div class="preview-progress-bar"></div></div>
        <span class="preview-check">✓</span>
        <span>${file.name}</span>`;
      preview.appendChild(div);
      previewItems.push({ file, div });
      const reader = new FileReader();
      reader.onload = ev => {
        const placeholder = div.querySelector('div:first-child');
        if (placeholder) {
          const img = document.createElement('img');
          img.src = ev.target.result;
          img.alt = '';
          div.replaceChild(img, placeholder);
        }
      };
      reader.readAsDataURL(file);
    });
  }

  uploadForm.addEventListener('submit', async e => {
    e.preventDefault();
    const items = [...previewItems];
    if (!items.length) return;
    submitBtn.disabled = true;
    for (let i = 0; i < items.length; i++) {
      submitBtn.textContent = `Upload (${i}/${items.length})…`;
      await uploadImage(items[i].file, ROOM_ID, items[i].div);
    }
    window.location.href = `/admin/chambres/edit/${ROOM_ID}?success=Photos+ajoutées`;
  });

  function uploadImage(file, roomId, thumb) {
    return new Promise(resolve => {
      const xhr = new XMLHttpRequest();
      const fd = new FormData();
      fd.append('image', file);
      const bar = thumb.querySelector('.preview-progress-bar');
      xhr.upload.addEventListener('progress', ev => {
        if (ev.lengthComputable)
          bar.style.width = Math.round(ev.loaded / ev.total * 100) + '%';
      });
      xhr.addEventListener('load', () => {
        thumb.classList.add(xhr.status < 300 ? 'upload-done' : 'upload-error');
        resolve();
      });
      xhr.addEventListener('error', () => { thumb.classList.add('upload-error'); resolve(); });
      xhr.open('POST', `/admin/chambres/${roomId}/images/single`);
      xhr.send(fd);
    });
  }

  /* ── Médiathèque ── */
  let libAllImages = [];
  let libSelected = new Set();

  async function openLibraryModal() {
    libSelected.clear();
    document.getElementById('libraryModal').style.display = 'flex';
    const resp = await fetch('/admin/media/list');
    libAllImages = await resp.json();
    renderLibrary(libAllImages);
  }
  function closeLibraryModal(e) {
    if (!e || e.target === document.getElementById('libraryModal'))
      document.getElementById('libraryModal').style.display = 'none';
  }
  function filterLibrary(q) {
    const filtered = q ? libAllImages.filter(i => i.filename.toLowerCase().includes(q.toLowerCase())) : libAllImages;
    renderLibrary(filtered);
  }
  function renderLibrary(items) {
    const grid = document.getElementById('libraryGrid');
    if (!items.length) { grid.innerHTML = '<p style="color:var(--muted);padding:1rem;">Aucune image.</p>'; return; }
    grid.innerHTML = items.map(item => `
      <div class="library-modal-item ${libSelected.has(item.filename) ? 'selected' : ''}"
        onclick="toggleLibItem('${item.filename}', this)">
        <img src="${item.url}" alt="" loading="lazy" decoding="async">
        <div class="lib-check">✓</div>
      </div>
    `).join('');
    updateLibCount();
  }
  function toggleLibItem(filename, el) {
    if (libSelected.has(filename)) { libSelected.delete(filename); el.classList.remove('selected'); }
    else { libSelected.add(filename); el.classList.add('selected'); }
    updateLibCount();
  }
  function updateLibCount() {
    document.getElementById('libSelCount').textContent = `${libSelected.size} sélectionnée(s)`;
  }
  async function confirmLibrarySelection() {
    if (!libSelected.size) { closeLibraryModal(); return; }
    const filenames = [...libSelected];
    const resp = await fetch(`/admin/chambres/${ROOM_ID}/images/from-library`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ filenames }),
    });
    if (resp.ok) {
      closeLibraryModal();
      window.location.href = `/admin/chambres/edit/${ROOM_ID}?success=Photos+ajoutées+depuis+la+médiathèque`;
    } else {
      alert('Erreur lors de l\'ajout.');
    }
  }
</script>
</body>
</html>
