<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin – Utilisateurs</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="icon" href="/image/logo.png" type="image/png">
</head>
<body class="admin-body">

<%- include('sidebar', { activePage: 'users', settings }) %>

<main class="admin-main">
  <div class="admin-topbar">
    <h1 class="admin-page-title">Utilisateurs</h1>
    <a href="/admin/utilisateurs/nouveau" class="btn-admin-primary btn-sm">+ Nouvel utilisateur</a>
  </div>
  <div class="admin-content">

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:0.4rem"><polyline points="20 6 9 17 4 12"/></svg> <%= success %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="table-wrap">
      <table class="admin-table">
        <thead>
          <tr><th>Nom</th><th>E-mail</th><th>Rôle</th><th>Statut</th><th>Créé le</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
          <tr>
            <td><strong><%= u.name %></strong></td>
            <td><%= u.email %></td>
            <td>
              <span class="status-badge" style="<%= u.role === 'superadmin' ? 'background:#fef9c3;color:#854d0e;' : u.role === 'editor' ? 'background:#eff6ff;color:#1d4ed8;' : 'background:#f0fdf4;color:#166534;' %>">
                <%= u.role %>
              </span>
            </td>
            <td>
              <span class="status-pill <%= u.active ? 'status-active' : 'status-inactive' %>">
                <%= u.active ? 'Actif' : 'Inactif' %>
              </span>
            </td>
            <td><%= new Date(u.createdAt).toLocaleDateString('fr-FR') %></td>
            <td class="actions-cell">
              <a href="/admin/utilisateurs/edit/<%= u.id %>" class="btn-xs btn-green">Modifier</a>
              <form method="POST" action="/admin/utilisateurs/toggle/<%= u.id %>" style="display:inline">
                <button type="submit" class="btn-xs btn-orange"><%= u.active ? 'Désactiver' : 'Activer' %></button>
              </form>
              <% if (u.id !== currentUser?.id) { %>
              <form method="POST" action="/admin/utilisateurs/delete/<%= u.id %>" style="display:inline"
                onsubmit="return confirm('Supprimer cet utilisateur ?')">
                <button type="submit" class="btn-xs btn-red">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                </button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </div>
</main>

<script src="/js/admin.js"></script>
</body>
</html>
